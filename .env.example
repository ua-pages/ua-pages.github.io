# Example environment variables for local development
# Copy this file to .env and fill real values before running the server.

# Port the server will listen on (default in code: 4200)
PORT=4200

# Telegram bot token and chat id used by the contact API
# Get a bot token from @BotFather and the chat id for your target chat
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# CORS origin allowed to call the /api/contact endpoint (use '*' to allow all)
CORS_ORIGIN=http://localhost:4200

# NODE_ENV (optional): development or production
NODE_ENV=development

